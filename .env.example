# --- GESTIFIQUE3 CONFIGURATION EXAMPLE ---
# Duplique este arquivo como .env e preencha as informacoes reais para producao.

NODE_ENV=production
PORT=3000
# JWT_SECRET: OBRIGATORIO. Use uma chave aleatoria com no minimo 32 caracteres.
# Gere uma com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# O boot em producao ABORTA se o segredo for curto (<32) ou um valor de exemplo conhecido.
JWT_SECRET=COLE_AQUI_UMA_CHAVE_ALEATORIA_FORTE_COM_MAIS_DE_32_CHARS

# --- BANCO DE DADOS (MYSQL / MARIADB) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=gestifique_db
DB_PORT=3306

# --- CONTA DE DESENVOLVEDOR INICIAL ---
# Usada apenas para o PRIMEIRO acesso (seed). Defina uma senha forte e unica
# e troque-a apos o primeiro login. NAO reutilize esta senha em outros lugares.
DEV_EMAIL=admin@gestifique.com.br
DEV_PASSWORD=DEFINA_UMA_SENHA_FORTE_E_UNICA

# --- PROXY & INFRAESTRUTURA ---
# TRUST_PROXY: necessario para que o express-rate-limit funcione corretamente atras de um proxy.
# Use '1' para Hostinger/Nginx/Cloudflare (confia no primeiro salto).
# Use 'false' para desenvolvimento local direto.
TRUST_PROXY=1

# --- CORS & SEGURANCA ---
# Separe multiplos dominios por virgula.
CORS_ORIGINS=https://gestifique.com.br,https://app.gestifique.com.br

# --- TLS DE E-MAIL ---
# Padrao SEGURO: a validacao de certificado TLS (SMTP/IMAP) fica ATIVA.
# Defina MAIL_TLS_INSECURE=true APENAS em ambiente controlado com certificado
# invalido/self-signed. Isso DESATIVA a validacao TLS e e INSEGURO (risco de MITM).
# Deixe ausente ou =false em producao real.
MAIL_TLS_INSECURE=false

# --- ESCALABILIDADE & PROCESSOS (WORKLOAD SEPARATION) ---
# Em servidores pequenos, mantenha ENABLE_WEB_SERVER=true e ENABLE_TICKET_JOBS=true.
# Deixe ENABLE_EMAIL_LISTENER=false ate configurar as credenciais IMAP corretamente.
ENABLE_WEB_SERVER=true
ENABLE_TICKET_JOBS=true
ENABLE_EMAIL_LISTENER=false

# --- STORAGE ---
# 'local' salva no disco da aplicacao. 's3' e 'gcs' reservados para o futuro.
STORAGE_TYPE=local
UPLOAD_DIR=uploads/tickets

# --- OMNICHANNEL / EMAIL LISTENER (OPCIONAL) ---
# Apenas ative se ENABLE_EMAIL_LISTENER=true e as credenciais abaixo estiverem preenchidas.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Configuracoes de recebimento inteligente.
INBOUND_EMAIL_DOMAIN=inbound.gestifique.com.br
INBOUND_EMAIL_PREFIX=canal
