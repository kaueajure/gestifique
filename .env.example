# --- GESTIFIQUE3 CONFIGURATION EXAMPLE ---
# Duplique este arquivo como .env e preencha as informações reais para produção.

NODE_ENV=production
PORT=3000
JWT_SECRET=mudar-isso-em-producao-com-chave-longa-e-segura

# --- BANCO DE DADOS (MYSQL / MARIADB) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=gestifique_db
DB_PORT=3306

# --- CONTA DE DESENVOLVEDOR INICIAL ---
# Use estas credenciais para o primeiro acesso ao painel
DEV_EMAIL=admin@gestifique.com.br
DEV_PASSWORD=mudar@123

# --- PROXY & INFRAESTRUTURA ---
# TRUST_PROXY: Necessário para que o express-rate-limit funcione corretamente atrás de um proxy.
# Use '1' para Hostinger/Nginx/Cloudflare (confia no primeiro salto).
# Use 'false' para desenvolvimento local direto.
TRUST_PROXY=1

# --- CORS & SEGURANÇA ---
# Separe múltiplos domínios por vírgula
CORS_ORIGINS=https://gestifique.com.br,https://app.gestifique.com.br

# --- ESCALABILIDADE & PROCESSOS (WORKLOAD SEPARATION) ---
# Em servidores pequenos (Hostinger compartilhado), mantenha ENABLE_WEB_SERVER=true e ENABLE_TICKET_JOBS=true.
# Deixe ENABLE_EMAIL_LISTENER=false até configurar as credenciais IMAP corretamente.

ENABLE_WEB_SERVER=true
ENABLE_TICKET_JOBS=true

# IMPORTANTE: No primeiro deploy, mantenha como false para evitar erros de conexão se não houver credenciais.
ENABLE_EMAIL_LISTENER=false

# --- STORAGE ---
# 'local' salva no disco da aplicação. 's3' e 'gcs' reservados para o futuro.
STORAGE_TYPE=local
UPLOAD_DIR=uploads/tickets

# --- OMNICHANNEL / EMAIL LISTENER (OPCIONAL) ---
# Apenas ative se ENABLE_EMAIL_LISTENER=true e as credenciais abaixo estiverem preenchidas.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Configurações de recebimento inteligente
INBOUND_EMAIL_DOMAIN=inbound.gestifique.com.br
INBOUND_EMAIL_PREFIX=canal
