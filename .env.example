# ==========================================
# GESTIFIQUE - VARIÁVEIS DE AMBIENTE
# NÃO COMMITAR O ARQUIVO .env REAL PARA O GITHUB!
# Em produção (Ex: Hostinger), preencha essas 
# variáveis diretamente no painel de controle.
# ==========================================

# App Config
NODE_ENV=development # Em produção na Hostinger, usar: production
PORT=3000            # A Hostinger geralmente fornece a porta ou usa 3000
JWT_SECRET=change_this_to_a_long_random_secret

# Database Config (MySQL Hostinger ou Local)
DB_HOST=localhost    # Exemplo Hostinger: srv1883.hstgr.io
DB_USER=root         # Exemplo Hostinger: u237752053_gestifique
DB_PASSWORD=         # Sua senha mestre do banco de dados
DB_NAME=gestifique   # Exemplo Hostinger: u237752053_gestifique
DB_PORT=3306

# Bootstrap Developer Account (Primeiro login)
DEV_EMAIL=admin@gestifique.com.br
DEV_PASSWORD=change_this_password

# CORS Config (Lista separada por vírgulas)
CORS_ORIGINS=https://gestifique.com.br,https://app.gestifique.com.br
